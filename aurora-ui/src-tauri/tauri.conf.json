{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aurora",
  "version": "0.2.0",
  "identifier": "net.auroraygg.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Aurora",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://localhost:* wss://localhost:* http://localhost:* ws://127.0.0.1:* http://127.0.0.1:* https://api.github.com https://raw.githubusercontent.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/airdcppd"],
    "resources": {
      "resources/nssm.exe": "resources/nssm.exe",
      "resources/dlls/*": "resources/dlls/",
      "resources/default-config/*": "resources/default-config/",
      "resources/yggdrasil-*-x64.msi": "resources/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "DC++ client for Yggdrasil mesh network",
    "longDescription": "Aurora is a modern DC++ file sharing client built for the Yggdrasil mesh network. Features real-time search, encrypted transfers, and an Apple-inspired dark UI.",
    "copyright": "2026 AuroraYgg",
    "category": "Utility",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "airdcppd",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
